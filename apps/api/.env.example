# --- Núcleo ---
NODE_ENV=development
PORT=4000

# Postgres local (docker-compose.dev.yml crea el rol/BD "wolfiax" sin superusuario
# para que Row-Level Security aplique igual que en producción)
DATABASE_URL=postgresql://wolfiax:wolfiax_dev@localhost:5432/wolfiax

# Origen del frontend (CORS + links de invitación)
WEB_ORIGIN=http://localhost:3000

# --- Cookies del refresh token ---
# En producción: COOKIE_SECURE=true y COOKIE_DOMAIN=.wolfiax.com
COOKIE_SECURE=false
# COOKIE_DOMAIN=

# --- JWT (RS256) ---
# Genera ambas claves con: node infra/scripts/generate-jwt-keys.mjs
JWT_PRIVATE_KEY_BASE64=
JWT_PUBLIC_KEY_BASE64=
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# --- Docs ---
SWAGGER_ENABLED=true

# --- F1: rol del proceso y Redis ---
# MODE: api | webhook | worker (F1 usa 'api' con worker embebido)
MODE=api
REDIS_URL=redis://localhost:6379

# URL pública de la API (redirect_uri de OAuth; en dev usa un túnel https,
# p. ej. `cloudflared tunnel --url http://localhost:4000`, porque Meta exige HTTPS)
API_PUBLIC_URL=http://localhost:4000

# --- F1: cifrado de tokens de Meta en reposo (32 bytes base64) ---
# Genérala con: node infra/scripts/generate-jwt-keys.mjs
TOKEN_ENC_KEY_BASE64=

# --- F1: credenciales de Meta (developers.facebook.com) ---
META_GRAPH_VERSION=v23.0
# App con producto "Facebook Login for Business" (vía facebook_login):
META_APP_ID=
META_APP_SECRET=
# Producto "Instagram API with Instagram Login" (vía instagram_login):
META_IG_APP_ID=
META_IG_APP_SECRET=
# Valor arbitrario que TÚ eliges; configúralo idéntico en el panel de Webhooks de Meta
META_WEBHOOK_VERIFY_TOKEN=

# --- Super Admin de plataforma (staff Wolfiax) ---
# Si defines email + password, el API crea/promueve este Super Admin al arrancar.
# Deja el password vacío en desarrollo si no lo necesitas.
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Wolfiax Super Admin
