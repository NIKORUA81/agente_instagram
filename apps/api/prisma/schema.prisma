generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  owner
  admin
  agent
  analyst
}

model Organization {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  plan        String    @default("trial")
  settings    Json      @default("{}")
  suspendedAt DateTime? @map("suspended_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships      Membership[]
  invitations      Invitation[]
  channels         Channel[]
  contacts         Contact[]
  conversations    Conversation[]
  messages         Message[]
  tags             Tag[]
  automations      Automation[]
  aiProfiles       AiProfile[]
  knowledgeSources KnowledgeSource[]
  chunks           Chunk[]
  catalogItems     CatalogItem[]
  flows            Flow[]
  flowVersions     FlowVersion[]
  flowExecutions   FlowExecution[]

  @@map("organizations")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @unique
  passwordHash    String?   @map("password_hash")
  fullName        String    @map("full_name")
  isPlatformAdmin Boolean   @default(false) @map("is_platform_admin")
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships           Membership[]
  refreshTokens         RefreshToken[]
  invitationsSent       Invitation[]   @relation("InvitedBy")
  assignedConversations Conversation[] @relation("AssignedAgent")
  sentMessages          Message[]      @relation("SentBy")
  notes                 Note[]

  @@map("users")
}

model Membership {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           Role
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("memberships")
}

model RefreshToken {
  id             String    @id @default(uuid()) @db.Uuid
  userId         String    @map("user_id") @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  tokenHash      String    @unique @map("token_hash")
  familyId       String    @map("family_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt      DateTime? @map("revoked_at") @db.Timestamptz(6)
  userAgent      String?   @map("user_agent")
  ip             String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId])
  @@map("refresh_tokens")
}

model Invitation {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  email          String
  role           Role
  tokenHash      String    @unique @map("token_hash")
  invitedById    String?   @map("invited_by_id") @db.Uuid
  expiresAt      DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt     DateTime? @map("accepted_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User?        @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("invitations")
}

model AuditLog {
  id             BigInt   @id @default(autoincrement())
  organizationId String?  @map("organization_id") @db.Uuid
  userId         String?  @map("user_id") @db.Uuid
  action         String
  resource       String?
  resourceId     String?  @map("resource_id")
  ip             String?
  userAgent      String?  @map("user_agent")
  detail         Json?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ---------------------------------------------------------------------------
// F1 - Canales (conexion Meta) e Inbox
// ---------------------------------------------------------------------------

model Channel {
  id                String    @id @default(uuid()) @db.Uuid
  organizationId    String    @map("organization_id") @db.Uuid
  type              String    @default("instagram")
  connectionType    String    @map("connection_type")
  igUserId          String    @unique @map("ig_user_id")
  igUsername        String    @map("ig_username")
  fbPageId          String?   @map("fb_page_id")
  accessTokenEnc    Bytes     @map("access_token_enc")
  tokenExpiresAt    DateTime? @map("token_expires_at") @db.Timestamptz(6)
  grantedScopes     String[]  @map("granted_scopes")
  status            String    @default("active")
  lastHealthCheckAt DateTime? @map("last_health_check_at") @db.Timestamptz(6)
  webhookSubscribed Boolean   @default(false) @map("webhook_subscribed")
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts      Contact[]
  conversations Conversation[]
  webhookEvents WebhookEvent[]
  automations   Automation[]
  aiProfile     AiProfile?
  flows         Flow[]

  @@index([organizationId])
  @@map("channels")
}

model WebhookEvent {
  id          String    @id @default(uuid()) @db.Uuid
  channelId   String?   @map("channel_id") @db.Uuid
  externalId  String    @map("external_id")
  eventType   String    @map("event_type")
  payload     Json
  processedAt DateTime? @map("processed_at") @db.Timestamptz(6)
  error       String?
  receivedAt  DateTime  @default(now()) @map("received_at") @db.Timestamptz(6)

  channel Channel? @relation(fields: [channelId], references: [id], onDelete: SetNull)

  @@unique([externalId, eventType])
  @@index([receivedAt])
  @@map("webhook_events")
}

model Contact {
  id            String   @id @default(uuid()) @db.Uuid
  organizationId String  @map("organization_id") @db.Uuid
  channelId     String   @map("channel_id") @db.Uuid
  igScopedId    String   @map("ig_scoped_id")
  username      String?
  name          String?
  profilePicUrl String?  @map("profile_pic_url")
  isFollower    Boolean? @map("is_follower")
  lifecycle     String   @default("new")
  extracted     Json     @default("{}")
  firstSeenAt   DateTime @default(now()) @map("first_seen_at") @db.Timestamptz(6)
  lastSeenAt    DateTime @default(now()) @map("last_seen_at") @db.Timestamptz(6)

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel       Channel        @relation(fields: [channelId], references: [id], onDelete: Cascade)
  conversations Conversation[]
  flowExecutions FlowExecution[]

  @@unique([channelId, igScopedId])
  @@index([organizationId])
  @@map("contacts")
}

model Conversation {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  channelId       String    @map("channel_id") @db.Uuid
  contactId       String    @map("contact_id") @db.Uuid
  status          String    @default("open")
  mode            String    @default("human")
  assignedUserId  String?   @map("assigned_user_id") @db.Uuid
  windowExpiresAt DateTime? @map("window_expires_at") @db.Timestamptz(6)
  lastMessageAt   DateTime? @map("last_message_at") @db.Timestamptz(6)
  lastInboundAt   DateTime? @map("last_inbound_at") @db.Timestamptz(6)
  firstResponseMs Int?      @map("first_response_ms")
  aiSummary       String?   @map("ai_summary")
  sentiment       String?
  language        String?
  intent          String?
  csatScore       Int?      @map("csat_score") @db.SmallInt
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel      Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)
  assignedUser User?             @relation("AssignedAgent", fields: [assignedUserId], references: [id], onDelete: SetNull)
  messages     Message[]
  tags         ConversationTag[]
  notes        Note[]
  flowExecutions FlowExecution[]

  @@unique([channelId, contactId])
  @@index([organizationId, channelId, status, lastMessageAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  direction      String
  source         String
  mid            String?  @unique
  type           String   @default("text")
  text           String?
  attachments    Json     @default("[]")
  replyToStory   Json?    @map("reply_to_story")
  status         String   @default("received")
  error          String?
  sentByUserId   String?  @map("sent_by_user_id") @db.Uuid
  aiMeta         Json?    @map("ai_meta")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sentBy       User?        @relation("SentBy", fields: [sentByUserId], references: [id], onDelete: SetNull)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// F2 - Etiquetas, notas y automatizaciones
// ---------------------------------------------------------------------------

model Tag {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String
  color          String   @default("#6366f1")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations ConversationTag[]

  @@unique([organizationId, name])
  @@map("tags")
}

model ConversationTag {
  conversationId String @map("conversation_id") @db.Uuid
  tagId          String @map("tag_id") @db.Uuid
  organizationId String @map("organization_id") @db.Uuid

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([conversationId, tagId])
  @@map("conversation_tags")
}

model Note {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  body           String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("notes")
}

model Automation {
  id              String    @id @default(uuid()) @db.Uuid
  organizationId  String    @map("organization_id") @db.Uuid
  channelId       String?   @map("channel_id") @db.Uuid
  name            String
  enabled         Boolean   @default(true)
  trigger         Json
  conditions      Json      @default("[]")
  actions         Json
  priority        Int       @default(100)
  cooldownSeconds Int       @default(60) @map("cooldown_seconds")
  fireCount       BigInt    @default(0) @map("fire_count")
  lastFiredAt     DateTime? @map("last_fired_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel      Channel?     @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([organizationId, enabled, priority])
  @@map("automations")
}

// ---------------------------------------------------------------------------
// F3 - Motor de IA y base de conocimiento (RAG)
// ---------------------------------------------------------------------------

model AiProfile {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  channelId          String    @unique @map("channel_id") @db.Uuid
  enabled            Boolean   @default(false)
  systemPrompt       String    @default("") @map("system_prompt")
  tone               String    @default("professional")
  languagePolicy     String    @default("mirror") @map("language_policy")
  disclosureMessage  String    @default("Hola, soy el asistente virtual del negocio. Con gusto te ayudo.") @map("disclosure_message")
  handoverKeywords   String[]  @default(["humano", "agente", "persona", "asesor"]) @map("handover_keywords")
  guardrails         Json      @default("{}")
  businessHours      Json?     @map("business_hours")
  monthlyTokenBudget BigInt?   @map("monthly_token_budget")
  tokensUsedMonth    BigInt    @default(0) @map("tokens_used_month")
  confidenceThreshold Float    @default(0.35) @map("confidence_threshold")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel      Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@map("ai_profiles")
}

model KnowledgeSource {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  type           String
  name           String
  r2Key          String?   @map("r2_key")
  url            String?
  status         String    @default("pending")
  error          String?
  chunkCount     Int       @default(0) @map("chunk_count")
  refreshedAt    DateTime? @map("refreshed_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  chunks       Chunk[]

  @@index([organizationId])
  @@map("knowledge_sources")
}

model Chunk {
  id             String                       @id @default(uuid()) @db.Uuid
  organizationId String                       @map("organization_id") @db.Uuid
  sourceId       String                       @map("source_id") @db.Uuid
  content        String
  metadata       Json                         @default("{}")
  embedding      Unsupported("vector(1024)")
  createdAt      DateTime                     @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  source       KnowledgeSource @relation(fields: [sourceId], references: [id], onDelete: Cascade)

  @@index([organizationId, sourceId])
  @@map("chunks")
}

model CatalogItem {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  sku            String?
  name           String
  description    String?
  price          Decimal? @db.Decimal(12, 2)
  currency       String   @default("USD")
  stock          Int?
  active         Boolean  @default(true)
  media          Json     @default("[]")
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("catalog_items")
}

// ---------------------------------------------------------------------------
// F4 - Flow Builder
// ---------------------------------------------------------------------------

model Flow {
  id                 String    @id @default(uuid()) @db.Uuid
  organizationId     String    @map("organization_id") @db.Uuid
  channelId          String?   @map("channel_id") @db.Uuid
  name               String
  description        String?
  enabled            Boolean   @default(false)
  status             String    @default("draft")
  trigger            Json      @default("{\"type\":\"manual\"}")
  graph              Json      @default("{\"nodes\":[],\"edges\":[]}")
  publishedVersionId String?   @map("published_version_id") @db.Uuid
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel      Channel?        @relation(fields: [channelId], references: [id], onDelete: SetNull)
  versions     FlowVersion[]   @relation("FlowVersions")
  executions   FlowExecution[]

  @@index([organizationId, enabled])
  @@map("flows")
}

model FlowVersion {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  flowId         String   @map("flow_id") @db.Uuid
  version        Int
  graph          Json
  trigger        Json
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flow         Flow            @relation("FlowVersions", fields: [flowId], references: [id], onDelete: Cascade)
  executions   FlowExecution[]

  @@unique([flowId, version])
  @@index([organizationId])
  @@map("flow_versions")
}

model FlowExecution {
  id             String    @id @default(uuid()) @db.Uuid
  organizationId String    @map("organization_id") @db.Uuid
  flowId         String    @map("flow_id") @db.Uuid
  flowVersionId  String    @map("flow_version_id") @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  contactId      String    @map("contact_id") @db.Uuid
  status         String    @default("running")
  currentNodeId  String?   @map("current_node_id")
  variables      Json      @default("{}")
  trace          Json      @default("[]")
  steps          Int       @default(0)
  wakeAt         DateTime? @map("wake_at") @db.Timestamptz(6)
  error          String?
  startedAt      DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  endedAt        DateTime? @map("ended_at") @db.Timestamptz(6)

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  flow         Flow         @relation(fields: [flowId], references: [id], onDelete: Cascade)
  flowVersion  FlowVersion  @relation(fields: [flowVersionId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([conversationId, status])
  @@index([organizationId, status])
  @@map("flow_executions")
}
