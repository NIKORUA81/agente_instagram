# Entorno
ENVIRONMENT=development
PORT=5000

# Token compartido para llamadas internas desde la API NestJS (X-Internal-Token).
# Genera uno aleatorio y ponlo también en el .env de apps/api (AI_SERVICE_TOKEN).
INTERNAL_API_TOKEN=


# Base de datos (la MISMA que la API; rol wolfiax sin superusuario, RLS activo)
DATABASE_URL=postgresql://wolfiax:wolfiax_dev@localhost:5432/wolfiax

# Anthropic (LLM). El valor es la CLAVE SECRETA (empieza por sk-ant-api03-...),
# NO el JSON de metadata que devuelve el endpoint de gestión de claves.
# Crea la clave en console.anthropic.com y cópiala una sola vez.
ANTHROPIC_API_KEY=

LLM_MODEL=claude-opus-4-8
LLM_EFFORT=medium

# Embeddings locales (fastembed / ONNX). El modelo se descarga la primera vez (~1GB).
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024

# RAG
RAG_TOP_K=8
